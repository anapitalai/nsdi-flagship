# SSH host or IP for the deploy target
DEPLOY_HOST=your-server-host

# SSH port used by the deploy target
DEPLOY_PORT=22

# SSH user that has write access to the deploy path
DEPLOY_USER=your-deploy-user

# Absolute remote path to sync into
DEPLOY_PATH=/path/to/deploy/directory

# Optional pinned host key output from ssh-keyscan -H
DEPLOY_KNOWN_HOSTS=

# MinIO object storage
MINIO_ENDPOINT=your-minio-host
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=nsdi-assets
MINIO_PUBLIC_BASE_URL=

# Auth.js / NextAuth
AUTH_SECRET=your-auth-secret
AUTH_GITHUB_ID=your-github-oauth-client-id
AUTH_GITHUB_SECRET=your-github-oauth-client-secret
